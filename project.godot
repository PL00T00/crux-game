config_version=5

[application]

config/name="Crux Game"
config/version="0.0.1"
run/main_scene="uid://vbdknh4l1ydq"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="uid://cilojgvyo1tjc"

[audio]

buses/default_bus_layout="uid://srx40t0urnsx"

[autoload]

Global="*uid://wd4k3tsb5dlg"
NotesManager="*uid://cqvygvoo2n2go"
CutsceneUi="*uid://wv4m8djm2xq"

[display]

